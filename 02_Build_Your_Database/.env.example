# Local Docker setup
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false

# Redis Cloud setup
# Copy the exact values from the Redis Cloud connection wizard.
# Never commit your real password.
# REDIS_HOST=your-cloud-endpoint
# REDIS_PORT=your-cloud-port
# REDIS_USERNAME=default
# REDIS_PASSWORD=replace-me
# REDIS_SSL=true
